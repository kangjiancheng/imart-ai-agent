ANTHROPIC_BASE_URL=xxx
ANTHROPIC_API_KEY=sk-xxx

# Milvus — Option A: Docker Milvus (default, uncomment and comment out Option B)
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=root:Milvus

# Milvus — Option B: Milvus Lite (no Docker needed)
# MILVUS_URI=./milvus_local.db
# MILVUS_TOKEN=


# Optional
TAVILY_API_KEY=

# Embeddings (required for RAG + vector memory)
OPENAI_API_KEY=

# Suppress HuggingFace tokenizer parallelism warning.
# The warning appears because FastAPI's async event loop conflicts with
# HuggingFace's internal process forking. Setting this to false tells
# tokenizers to use single-threaded mode, which is safe for our use case.
TOKENIZERS_PARALLELISM=false