# Virtual environment — never copy into image
venv/
.venv/

# Secrets — never bake into image
.env

# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Model weights cache — mounted as a Docker volume instead
.cache/

# Milvus local database and generated config files
*.db
volumes/
embedEtcd.yaml
user.yaml

# Git and editor
.git/
.gitignore
.DS_Store
*.swp

# Tests — not needed at runtime
tests/

# Docs and scripts — not needed inside the container
*.md
standalone_embed.sh
docker-compose*.yml
Dockerfile*
