ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: proxy or on-prem Anthropic endpoint
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Milvus — Option A: Docker Milvus (default)
MILVUS_URI=http://localhost:19530
MILVUS_TOKEN=root:Milvus

# Milvus — Option B: Milvus Lite (no Docker, file-based)
# MILVUS_URI=./milvus_local.db
# MILVUS_TOKEN=

# Optional: Tavily web search (free tier: 1,000 searches/month)
# Get your key at https://tavily.com
# TAVILY_API_KEY=tvly-xxx

# Suppress HuggingFace tokenizer parallelism warning
TOKENIZERS_PARALLELISM=false
